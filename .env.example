# ─── Backend API ──────────────────────────────────────────────────────────────
# URL base del backend Django. El frontend concatena los endpoints aquí.
# Desarrollo local Django:   http://localhost:8000/api
# Desarrollo local FastAPI:  http://localhost:5000/api
VITE_API_URL=http://localhost:8000/api

# Activar conexión real al backend (true) o usar datos demo en memoria (false).
# Dejar en false mientras desarrollas solo el frontend sin backend.
# Cambiar a true cuando el backend Django esté corriendo.
VITE_USE_API=false

# ─── Datos del negocio (opcionales, sobreescriben los defaults) ────────────────
# VITE_COMPANY_NAME=Mi Negocio
# VITE_COMPANY_RUC=20000000000
# VITE_COMPANY_ADDRESS=Av. Principal 123
# VITE_COMPANY_PHONE=01-000-0000
